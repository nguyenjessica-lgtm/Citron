--- a/CMakeLists.txt	2026-07-08 02:21:37.191700959 +0000
+++ b/CMakeLists.txt	2026-07-08 02:21:46.373120833 +0000
@@ -486,12 +486,19 @@
       target_compile_definitions(opus PRIVATE OPUS_X86_MAY_HAVE_SSE4_1)
       if(NOT MSVC)
         set_source_files_properties(${celt_sources_sse4_1} ${silk_sources_sse4_1} ${dnn_sources_sse4_1} PROPERTIES COMPILE_FLAGS -msse4.1)
+      elseif(CMAKE_C_COMPILER_ID STREQUAL "Clang" AND CMAKE_C_SIMULATE_ID STREQUAL "MSVC")
+        # clang-cl reports MSVC=TRUE (it simulates the cl.exe command line),
+        # but unlike real cl.exe it still enforces target-feature gating on
+        # always_inline SSE4.1/SSSE3 intrinsics, so it needs these flags too.
+        set_source_files_properties(${celt_sources_sse4_1} ${silk_sources_sse4_1} ${dnn_sources_sse4_1} PROPERTIES COMPILE_FLAGS "/clang:-msse4.1 /clang:-mssse3")
       endif()
 
       if(OPUS_FIXED_POINT)
         add_sources_group(opus silk ${silk_sources_fixed_sse4_1})
